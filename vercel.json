{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-backend-url.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/public/$1",
      "check": true
    },
    {
      "source": "/(.*)",
      "destination": "/public/index.html"
    }
  ]
}
